# ============================================================================
# FMP RM-API — variáveis de ambiente
#
# Em produção (EasyPanel/Docker) a fonte de verdade é a aba Environment do
# painel; este arquivo serve de referência e de fallback para dev local
# (Env::load só usa o .env quando a variável NÃO existe no ambiente real).
# Tabela completa com observações: docs/DEPLOY-EASYPANEL.md.
# ============================================================================

# ---------- Aplicação ----------
APP_DEBUG="false"
# APP_BASE é lido pela config mas HOJE é ignorado: public/index.php usa
# setBasePath('') fixo — a API serve na RAIZ (/pessoas, /financeiro/baixas...).
APP_BASE=""

# Chave de 32 bytes EXATOS (AES-256-GCM dos tokens de SSO em /sso/{token}).
APP_CRYPTO_KEY="chave-de-32-bytes-exatos-aqui!!!"
APP_CRYPTO_METHOD="aes-256-gcm"

# Autenticação da API. Quando definida, toda requisição exige o header
# X-API-Key (ou Authorization: Bearer). Isentos: /status e /sso/{token}.
# EM PRODUÇÃO (APP_DEBUG=false) a chave é OBRIGATÓRIA: vazia, as rotas não
# isentas respondem 503. Para rodar deliberadamente sem autenticação,
# defina API_KEY_OPCIONAL=true.
API_KEY=""
#API_KEY_OPCIONAL="false"

# CORS: origens permitidas, separadas por vírgula. "*" = aberto (default).
# Ex.: CORS_ALLOWED_ORIGINS="https://app.fmp.edu.br,https://admin.fmp.edu.br"
#CORS_ALLOWED_ORIGINS="*"

# ---------- TOTVS RM (SOAP) ----------
# Define a BASE que a API inteira consulta/grava.
#   Produção: https://fundacaoescola114384.rm.cloudtotvs.com.br:8051
#   Homolog : https://fundacaoescola114385.rm.cloudtotvs.com.br:8051
TOTVS_WS_URL="https://seu-ambiente.rm.cloudtotvs.com.br:8051"
TOTVS_WS_USER="usuario.integracao"
TOTVS_WS_PASSWORD="senha"

# Portal do aluno (links de login/autologin; NÃO afeta o SOAP).
# Defaults no código = produção (114384); em homolog aponte para 114385.
#TOTVS_PORTAL_LOGIN_URL="https://fundacaoescola114384.rm.cloudtotvs.com.br/FrameHTML/Web/App/Edu/PortalEducacional/login/"
#TOTVS_PORTAL_AUTOLOGIN_URL="https://fundacaoescola114384.rm.cloudtotvs.com.br/Corpore.Net/Source/EDU-EDUCACIONAL/Public/EduPortalAlunoLogin.aspx?AutoLoginType=ExternalLogin&redirect=financeiro.new"
#TOTVS_PORTAL_ALIAS="CorporeRM"

# ---------- Financeiro ----------
# Baixa de lançamento (POST /financeiro/baixas). Defaults do código já são os
# validados: FinTBCBaixaDataProcess + ExecuteWithXMLParams. Só sobrescreva
# se souber exatamente por quê (ver config/rm.php).
#FIN_BAIXA_PROCESSO="FinTBCBaixaDataProcess"
#FIN_BAIXA_OPERACAO="ExecuteWithXMLParams"
# Conta/caixa default da baixa quando CODCXA não vier no corpo.
#FIN_CODCXA_PADRAO=""
# ID do relatório de contrato (pode variar entre bases). Default: 1664.
#FIN_RELATORIO_CONTRATO_ID="1664"
