{
    "name": "fmp-mcp-apitotvs",
    "version": "1.0.0",
    "description": "Servidor MCP (Streamable HTTP + OAuth 2.1) da API de integração TOTVS RM da FMP",
    "type": "module",
    "private": true,
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "start": "node dist/server.js",
        "dev": "npm run build && node dist/server.js",
        "smoke": "node scripts/smoke.mjs",
        "test": "npm run build && npm run smoke"
    },
    "engines": {
        "node": ">=20"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.29.0",
        "express": "^5.2.1",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@types/express": "^5.0.6",
        "@types/node": "^26.1.1",
        "typescript": "^7.0.2"
    }
}
