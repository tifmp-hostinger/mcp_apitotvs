# ============================================================================
# MCP TOTVS FMP — variáveis de ambiente
#
# Em produção (EasyPanel/Docker) a fonte de verdade é a aba Environment do
# painel; este arquivo é referência para dev local. Com NODE_ENV=production,
# MCP_PUBLIC_URL, MCP_OAUTH_SIGNING_KEY e MCP_ACCESS_PASSWORD são
# OBRIGATÓRIAS (o boot aborta sem elas).
# ============================================================================

# Porta HTTP interna do serviço.
PORT=3300

# URL PÚBLICA deste servidor MCP (issuer OAuth). Sem barra final.
# Ex.: https://mcp-totvs.fmp.edu.br
MCP_PUBLIC_URL=""

# ---------- API TOTVS (a API REST deste repositório, www/api) ----------
# Base da API que o MCP gerencia.
TOTVS_API_BASE_URL="https://api-totvs.fmp.edu.br"
# Chave enviada no header X-API-Key (a mesma env API_KEY da API PHP).
TOTVS_API_KEY=""
# Timeout das chamadas (processos do RM são lentos; a API usa 300s).
#TOTVS_API_TIMEOUT_MS="300000"

# ---------- OAuth 2.1 ----------
# Segredo HS256 dos tokens (>= 32 caracteres). Gere com:
#   openssl rand -hex 32
MCP_OAUTH_SIGNING_KEY=""

# Senha pedida na tela de autorização do fluxo OAuth (quem conecta um
# cliente MCP precisa digitá-la uma vez, no navegador).
MCP_ACCESS_PASSWORD=""

# Tokens Bearer ESTÁTICOS aceitos além do OAuth (separados por vírgula).
# Para clientes headless (ex.: OpenClaw em servidor, n8n) onde o fluxo de
# navegador é inviável. Gere valores longos: openssl rand -hex 32.
# Vazio = somente OAuth.
MCP_STATIC_BEARER_TOKENS=""

# TTLs dos tokens (segundos). Defaults: 1h / 30d.
#MCP_ACCESS_TOKEN_TTL_SECONDS="3600"
#MCP_REFRESH_TOKEN_TTL_SECONDS="2592000"

# ---------- Diversos ----------
# Origens CORS permitidas ("*" = aberto; necessário para clientes em navegador).
#MCP_CORS_ORIGINS="*"
# Diretório dos clients OAuth registrados (monte volume p/ persistir).
#MCP_DATA_DIR="data"
