# ============================================================================
# MCP TOTVS FMP — variáveis de ambiente
#
# Em produção (EasyPanel/Docker) a fonte de verdade é a aba Environment do
# painel; este arquivo é referência para dev local. Com NODE_ENV=production,
# MCP_PUBLIC_URL, MCP_OAUTH_SIGNING_KEY e MCP_ACCESS_PASSWORD são
# OBRIGATÓRIAS (o boot aborta sem elas).
#
# As envs do TOTVS usam OS MESMOS NOMES da antiga API PHP (www/api) —
# migração 1:1 dos valores do painel.
# ============================================================================

# Porta HTTP interna do serviço.
PORT=3300

# URL PÚBLICA deste servidor MCP (issuer OAuth e base dos links /sso).
# Ex.: https://mcp-totvs.fmp.edu.br  (sem barra final)
MCP_PUBLIC_URL=""

# ---------- TOTVS RM (SOAP direto) ----------
# Base SOAP que o servidor inteiro consulta/grava.
#   Produção: https://fundacaoescola114384.rm.cloudtotvs.com.br:8051
#   Homolog : https://fundacaoescola114385.rm.cloudtotvs.com.br:8051
TOTVS_WS_URL=""
TOTVS_WS_USER=""
TOTVS_WS_PASSWORD=""
# Timeout das chamadas SOAP (processos do RM são lentos). Default 300s.
#TOTVS_WS_TIMEOUT_MS="300000"

# Chave de 32 bytes EXATOS (AES-256-GCM dos tokens de SSO em /sso/{token}).
# A MESMA APP_CRYPTO_KEY da API PHP mantém tokens antigos válidos.
APP_CRYPTO_KEY=""

# Logs verbosos das chamadas SOAP + XMLs nos envelopes de erro.
#APP_DEBUG="false"

# Portal do aluno (links de login/autologin; NÃO afeta o SOAP).
# Defaults no código = produção (114384); em homolog aponte para 114385.
#TOTVS_PORTAL_LOGIN_URL=""
#TOTVS_PORTAL_AUTOLOGIN_URL=""
#TOTVS_PORTAL_ALIAS="CorporeRM"

# ---------- Financeiro ----------
# Baixa de lançamento. Defaults já são os validados em homolog (13/07/2026):
# FinTBCBaixaDataProcess + ExecuteWithXMLParams. Só sobrescreva sabendo por quê.
#FIN_BAIXA_PROCESSO="FinTBCBaixaDataProcess"
#FIN_BAIXA_OPERACAO="ExecuteWithXMLParams"
# Conta/caixa default da baixa quando CODCXA não vier na chamada.
#FIN_CODCXA_PADRAO=""
# ID do relatório de contrato (pode variar entre bases). Default: 1664.
#FIN_RELATORIO_CONTRATO_ID="1664"

# ---------- OAuth 2.1 do MCP ----------
# Segredo HS256 dos tokens (>= 32 caracteres). Gere com: openssl rand -hex 32
MCP_OAUTH_SIGNING_KEY=""

# Senha pedida na tela de autorização do fluxo OAuth (quem conecta um
# cliente MCP digita uma vez, no navegador).
MCP_ACCESS_PASSWORD=""

# Tokens Bearer ESTÁTICOS aceitos além do OAuth (separados por vírgula).
# Para clientes headless (ex.: OpenClaw em servidor) onde o fluxo de
# navegador é inviável. Gere valores longos: openssl rand -hex 32.
# Vazio = somente OAuth.
MCP_STATIC_BEARER_TOKENS=""

# TTLs dos tokens (segundos). Defaults: 1h / 30d.
#MCP_ACCESS_TOKEN_TTL_SECONDS="3600"
#MCP_REFRESH_TOKEN_TTL_SECONDS="2592000"

# Client OAuth PRÉ-CONFIGURADO (opcional). Use quando o registro automático
# (Dynamic Client Registration) do conector do Claude/Cowork falhar com
# "não foi possível registrar no serviço de login". Defina um id qualquer
# (ex.: openssl rand -hex 16) e cole-o no campo "OAuth Client ID" do conector.
#MCP_OAUTH_CLIENT_ID=""
# Redirect URIs aceitas por esse client. Default já cobre os callbacks do
# Claude (claude.ai/claude.com). Se o Claude exibir outra "Callback URL",
# coloque-a aqui (separadas por vírgula).
#MCP_OAUTH_REDIRECT_URIS="https://claude.ai/api/mcp/auth_callback,https://claude.com/api/mcp/auth_callback"
# Rate-limit interno do SDK nas rotas OAuth. Desligado por padrão porque erra
# o IP atrás de proxy (EasyPanel/Traefik) e pode derrubar o registro. A tela
# de senha tem limitador próprio. Reative com "on" se rodar sem proxy.
#MCP_OAUTH_RATE_LIMIT="off"

# ---------- Diversos ----------
# Origens CORS permitidas ("*" = aberto; necessário para clientes em navegador).
#MCP_CORS_ORIGINS="*"
# Diretório dos clients OAuth registrados (monte volume p/ persistir).
#MCP_DATA_DIR="data"
